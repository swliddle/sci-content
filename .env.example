# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# All variables here are read by tools/lib/db.ts or the Makefile; per-target
# directory overrides (XML_DIR, OUT_DIR, DB_DIR, etc.) are set by Make recipes
# and do not need to live in .env.

# MySQL connection used by every tool that touches the sci2 database.
DB_HOST=127.0.0.1
DB_PORT=13306
DB_NAME=sci2p
DB_USER=
DB_PASSWORD=

# Remote target for `make jod-publish-NN` (scp destination for JoD HTML).
SCP_HOST=user@host.example.edu
JOD_REMOTE_DIR=/var/www/jod/div
