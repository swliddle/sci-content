                            <h1>
                            El Sacerdocio Aar&oacute;nico: &ldquo;Regresemos con honor&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1990/05/20.p" class="" id="p">Obispo Robert D Hales</p>
				<p uri="/liahona/1990/05/20.p" class="" id="p">Obispo Presidente</p>
