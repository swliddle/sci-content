                            <h1>
                            La Expiaci&oacute;n puede asegurar tu paz y tu felicidad
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Richard G. Scott" data-desktop="/bc/content/shared/content/images/leaders/richard-g-scott-10.jpg">
                                            <img src="/bc/content/shared/content/images/leaders/richard-g-scott-10.jpg" class="img-decor" alt="Richard G. Scott">
