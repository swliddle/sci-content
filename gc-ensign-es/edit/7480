                            <h1>
                            Reclamar las preciosas y grand&iacute;simas promesas
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Spencer J. Condie" data-desktop="/bc/content/shared/content/images/leaders/spencer-j-condie-10.jpg">
