                            <h1>
                            &iquest;Robar&aacute; el hombre a Dios?
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Yoshihiko Kikuchi" data-desktop="/bc/content/shared/content/images/leaders/yoshihiko-kikuchi-10.jpg">
