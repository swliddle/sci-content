                            <h1>
                            Cuatro verdades absolutas que proveen una br&uacute;jula infalible de la moral
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1997/10/5.p" class="" id="p">Elder Richard B. Wirthlin</p>
				<p uri="/liahona/1997/10/5.p" class="" id="p">de los Setenta</p>
			</div>
                                    </section>
