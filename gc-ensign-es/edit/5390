                            <h1>
                            No Toquen El Don Mal Ni La Cosa Impura
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/11/19.p" class="" id="p">Elder H. Burke Peterson</p>
				<p uri="/liahona/1993/11/19.p" class="" id="p">Miembro em&eacute;rito de los Setenta</p>
