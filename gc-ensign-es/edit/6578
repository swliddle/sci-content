                            <h1>
                            No es bueno que el hombre ni la mujer est&eacute;n solos
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2001/10/6.p" class="" id="p">Sheri L. Dew</p>
				<p uri="/liahona/2001/10/6.p" class="" id="p">Segunda Consejera de la Presidencia General de la Sociedad de Socorro </p>
			</div>
                                    </section>
