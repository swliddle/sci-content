                                <h1>
                                <h1 data-aid="134804154" id="title1">El sacerdocio y el poder redentor del Salvador</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Elder Dale G. Renlund" data-desktop="https://broadcast.lds.org/crowdsource/mobile/images/1658854/f6838dbffca6469c841b97cab319324e/100x139.jpg">
