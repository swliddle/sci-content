                            <h1>
                            ¿Dónde está el pabellón?
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Henry B. Eyring" data-desktop="/bc/content/shared/content/images/leaders/henry-b-eyring-10.jpg">
