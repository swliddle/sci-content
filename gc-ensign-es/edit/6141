                            <h1>
                            &ldquo;&iquest;Con Qu&eacute; Potestad &hellip; Hab&eacute;is Hecho Vosotros Esto?&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1998/11/20.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/1998/11/20.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
			</div>
