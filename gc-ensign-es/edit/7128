                            <h1>
                            El apreciar el consejo de los ya &ldquo;entrados en a&ntilde;os&rdquo;
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Stephen B. Oveson" data-desktop="/bc/content/shared/content/images/leaders/stephen-b-oveson-10.jpg">
