                            <h1>
                            &ldquo;Orad al padre en mi nombre&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1997/04/33.p" class="" id="p">Elder L. Edward Brown</p>
				<p uri="/liahona/1997/04/33.p" class="" id="p">de los Setenta</p>
