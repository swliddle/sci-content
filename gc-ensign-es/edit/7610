                            <h1>
                            Dios ama a todos Sus hijos y los ayuda
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Keith B. McMullin" data-desktop="/bc/content/shared/content/images/leaders/keith-b-mcmullin-10.jpg">
