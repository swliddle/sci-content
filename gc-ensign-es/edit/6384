                            <h1>
                            El ser mujer: El m&aacute;s alto lugar de honor
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2000/05/40.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/2000/05/40.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
