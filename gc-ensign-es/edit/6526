                            <h1>
                            Unidos en amor y testimonio
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2001/05/32.p" class="" id="p">&Eacute;lder John K. Carmack</p>
				<p uri="/liahona/2001/05/32.p" class="" id="p">De los Setenta</p>
			</div>
                                    </section>
                            <section class="sash-icons">
