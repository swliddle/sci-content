                            <h1>
                            Que nuestros ni&ntilde;os puedan ver la faz del Salvador
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Cheryl C. Lant" data-desktop="/bc/content/shared/content/images/leaders/cheryl-c-lant-10.jpg">
