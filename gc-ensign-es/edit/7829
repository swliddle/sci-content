                            <h1>
                            El perfecto amor echa fuera el temor
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="L. Tom Perry" data-desktop="/bc/content/shared/content/images/leaders/l-tom-perry-10.jpg">
