                            <h1>
                            El matrimonio y la familia: Nuestra sagrada responsabilidad
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="W. Douglas Shumway" data-desktop="/bc/content/shared/content/images/leaders/w-douglas-shumway-10.jpg">
