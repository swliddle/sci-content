                                    <div class="byline">
				<p uri="/liahona/2002/11/7.p2" class="" id="p2">&Eacute;lder Neal A. Maxwell</p>
				<p uri="/liahona/2002/11/7.p3" class="" id="p3">Del Qu&oacute;rum de los Doce Ap&oacute;stoles</p>
			</div>
