                            <h1>
                            Nacer de nuevo
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2001/05/24.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/2001/05/24.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
			</div>
