                            <h1>
                            Receta Divina Para La Curaci&oacute;n Espiritual
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1994/04/8.p" class="" id="p">Elder Malcolm S. Jeppsen</p>
				<p uri="/liahona/1994/04/8.p" class="" id="p">De los Setenta</p>
