                            <h1>
                            Un Convenio De Amor
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1995/04/14.p" class="" id="p">Aileen H. Clyde</p>
				<p uri="/liahona/1995/04/14.p" class="" id="p">Segunda Consejera de la Presidencia General de la Sociedad de Socorro</p>
			</div>
