                            <h1>
                            La Expiaci&oacute;n, el arrepentimiento y la ropa sucia
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Lynn A. Mickelsen" data-desktop="/bc/content/shared/content/images/leaders/lynn-a-mickelsen-10.jpg">
