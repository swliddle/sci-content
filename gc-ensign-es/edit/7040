                            <h1>
                            Tiempos peligrosos
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Cecil O. Samuelson Jr." data-desktop="/bc/content/shared/content/images/leaders/cecil-o-samuelson-jr-10.jpg">
