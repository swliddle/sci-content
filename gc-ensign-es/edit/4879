                            <h1>
                            Las ense&ntilde;anzas de un Padre amoroso
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1990/05/35.p" class="" id="p">por &eacute;l &eacute;lder Horacio A. Tenorio</p>
				<p uri="/liahona/1990/05/35.p" class="" id="p">de los Setenta</p>
