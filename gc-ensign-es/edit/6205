                            <h1>
                            Esta Es Nuestra &Eacute;poca
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1999/04/8.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/1999/04/8.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
			</div>
