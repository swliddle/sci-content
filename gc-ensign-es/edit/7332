                                            <h4><a href="#" class="show">Mostrar las referencias</a></h4>
                                            
                                            <ol> <h3 class="title">Notas</h3> <li class="footnote " id="footnote1-26991_002_010"><a name="-26991_002_010">&nbsp;</a>
				<span class="label">
	<a name="footnote1-26991_002_010">1.</a>
