                            <h1>
                            Escuchad El Llamado
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/05/16.p" class="" id="p">Elder Adney Y. Komatsu</p>
				<p uri="/liahona/1992/05/16.p" class="" id="p">De los Setenta</p>
