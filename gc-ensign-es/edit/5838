                            <h1>
                            El Salvador Cuenta Con Ustedes
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1996/11/17.p" class="" id="p">Elder Joe J. Christensen</p>
				<p uri="/liahona/1996/11/17.p" class="" id="p">de la Presidencia de los Setenta</p>
