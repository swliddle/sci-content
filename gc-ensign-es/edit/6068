                            <h1>
                            Contemplad a Dios Y Vivid
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Thomas S. Monson" data-desktop="/bc/content/shared/content/images/leaders/thomas-s-monson-10.jpg">
