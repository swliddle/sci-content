                            <h1>
                            No Estamos Solas
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1998/11/39.p" class="" id="p">Sheri L. Dew</p>
				<p uri="/liahona/1998/11/39.p" class="" id="p">Segunda Consejera de la Presidencia General de la Sociedad de Socorro</p>
			</div>
