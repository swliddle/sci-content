                            <h1>
                            El templo tiene que ver con las familias
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2006/11/5.p2" class="" id="p2">&Eacute;lder Richard H. Winkel</p>
				<p uri="/liahona/2006/11/5.p3" class="" id="p3">De los Setenta</p>
