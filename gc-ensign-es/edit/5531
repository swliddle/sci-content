                            <h1>
                            Construyamos Fortalezas
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1994/10/10.p" class="" id="p">Elder Horacio A. Tenorio</p>
				<p uri="/liahona/1994/10/10.p" class="" id="p">Recientemente relevado como miembro de los Setenta</p>
