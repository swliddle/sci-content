                            <h1>
                            Testigos
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1995/11/14.p" class="" id="p">Elder Loren C. Dunn </p>
				<p uri="/liahona/1995/11/14.p" class="" id="p">de los Setenta</p>
			</div>
