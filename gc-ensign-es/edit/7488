                            <h1>
                            No apaguen el Esp&iacute;ritu que vivifica al hombre interior
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Keith K. Hilbig" data-desktop="/bc/content/shared/content/images/leaders/keith-k-hilbig-10.jpg">
                                            <img src="/bc/content/shared/content/images/leaders/keith-k-hilbig-10.jpg" class="img-decor" alt="Keith K. Hilbig">
                                          </noscript>
                                        </figure>
