                            <h1>
                            El poder del sacerdocio
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1997/04/21.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/1997/04/21.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
