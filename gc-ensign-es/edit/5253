                            <h1>
                            La sabidur&iacute;a que lleva a la salvaci&oacute;n
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/11/32.p" class="" id="p">Elder John E. Fowler</p>
				<p uri="/liahona/1992/11/32.p" class="" id="p">De los Setenta</p>
			</div>
