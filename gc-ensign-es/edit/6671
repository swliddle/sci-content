                            <h1>
                            El idioma del amor
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Gayle M. Clegg" data-desktop="/bc/content/shared/content/images/leaders/gayle-m-clegg-10.jpg">
