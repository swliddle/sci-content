                            <h1>
                            Nuestro Mensaje Al Mundo
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1995/11/26.p" class="" id="p">Elder Robert E. Wells </p>
				<p uri="/liahona/1995/11/26.p" class="" id="p">de los Setenta</p>
			</div>
                                    </section>
