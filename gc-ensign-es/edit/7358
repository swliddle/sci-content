                            <h1>
                            El acercarnos m&aacute;s a &Eacute;l
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Craig A. Cardon" data-desktop="/bc/content/shared/content/images/leaders/craig-a-cardon-10.jpg">
