                            <h1>
                            &ldquo;Si est&aacute;is preparados, no temer&eacute;is&rdquo;
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Gordon B. Hinckley" data-desktop="/bc/content/shared/content/images/leaders/gordon-b-hinckley-10.jpg">
