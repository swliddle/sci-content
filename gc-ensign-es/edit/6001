                            <h1>
                            Hagamos que la fe se convierta en realidad
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1997/10/30.p" class="" id="p">Janette Hales Beckham</p>
				<p uri="/liahona/1997/10/30.p" class="" id="p">Presidenta General de los Mujeres J&oacute;venes, reci&eacute;n relevada</p>
			</div>
                                    </section>
