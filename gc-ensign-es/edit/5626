                            <h1>
                            Regocij&eacute;monos En Nuestros Convenios
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1995/04/32.p" class="" id="p">Bonnie D. Parkin</p>
				<p uri="/liahona/1995/04/32.p" class="" id="p">Segunda Consejera de la Presidencia General de las Mujeres J&oacute;venes</p>
			</div>
                                    </section>
