                            <h1>
                            &ldquo;Exam&iacute;name, oh Dios, Y Conoce Mi Coraz&oacute;n&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1998/04/8.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/1998/04/8.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
