                            <h1>
                            Confirmadas En La Fe
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1996/11/33.p" class="" id="p">Aileen H. Clyde</p>
				<p uri="/liahona/1996/11/33.p" class="" id="p">Segundo consejera de la Presidencia General de la Sociedad de Socorro</p>
			</div>
                                    </section>
