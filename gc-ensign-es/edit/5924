                            <h1>
                            Una peque&ntilde;a piedra
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1997/04/31.p" class="" id="p">Elaine L. Jack</p>
				<p uri="/liahona/1997/04/31.p" class="" id="p">Presidenta general de la Sociedad de Socorro, reci&eacute;n relevada</p>
			</div>
                                    </section>
