                                    <div class="byline">
				<p uri="/liahona/2000/11/8.p" class="" id="p">Margaret D. Nadauld</p>
				<p uri="/liahona/2000/11/8.p" class="" id="p">Presidenta General de las Mujeres J&oacute;venes</p>
			</div>
