                                    <div class="byline">
				<p uri="/liahona/2008/11/11.p2" class="" id="p2">&Eacute;lder Joseph B. Wirthlin</p>
				<p uri="/liahona/2008/11/11.p3" class="" id="p3">Del Qu&oacute;rum de los Doce Ap&oacute;stoles</p>
			</div>
