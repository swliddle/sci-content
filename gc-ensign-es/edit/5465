                            <h1>
                            &ldquo;Apacienta Mis Ovejas&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1994/04/21.p" class="" id="p">Elder Richard P. Lindsay</p>
				<p uri="/liahona/1994/04/21.p" class="" id="p">De los Setenta</p>
