                            <h1>
                            La edificaci&oacute;n del reino
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Bruce D. Porter" data-desktop="/bc/content/shared/content/images/leaders/bruce-d-porter-10.jpg">
