                            <h1>
                            &lsquo;&lsquo;Escudri&ntilde;ad Las Escrituras&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/05/7.p" class="" id="p">Elder L Lionel Kendrick</p>
