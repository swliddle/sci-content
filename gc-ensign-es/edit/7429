                            <h1>
                            &ldquo;Mam&aacute;, &iquest;somos cristianos?&rdquo;
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Gary J. Coleman" data-desktop="/bc/content/shared/content/images/leaders/gary-j-coleman-10.jpg">
