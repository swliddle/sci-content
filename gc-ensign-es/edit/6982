                            <h1>
                            Todas las cosas obrar&aacute;n juntamente para vuestro bien
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Susan W. Tanner" data-desktop="/bc/content/shared/content/images/leaders/susan-w-tanner-10.jpg">
