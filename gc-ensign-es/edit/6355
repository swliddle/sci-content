                            <h1>
                            El escudo de la fe
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2000/05/8.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/2000/05/8.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
