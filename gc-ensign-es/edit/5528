                            <h1>
                            Las Asambleas Solemnes
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="David B. Haight" data-desktop="/bc/content/shared/content/images/leaders/david-b-haight-10.jpg">
