                            <h1>
                            La caridad: amor perfecto y eterno
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Gene R. Cook" data-desktop="/bc/content/shared/content/images/leaders/gene-r-cook-10.jpg">
