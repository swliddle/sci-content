                            <h1>
                            La Fe Aumenta El Poder En El Sacerdocio
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/05/20.p" class="" id="p">Elder John K Carmack</p>
				<p uri="/liahona/1993/05/20.p" class="" id="p">De los Setenta</p>
