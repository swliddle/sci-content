                            <h1>
                            El Poder De La Bondad
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1995/11/6.p" class="" id="p">Hermana Janette Hales Beckham</p>
				<p uri="/liahona/1995/11/6.p" class="" id="p">Presidenta General de las Mujeres J&oacute;venes</p>
