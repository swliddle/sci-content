                            <h1>
                            La Verdadera Felicidad
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/11/32.p" class="" id="p">Elder W. Eugene Hansen</p>
				<p uri="/liahona/1993/11/32.p" class="" id="p">De la Presidencia de los Setenta</p>
			</div>
