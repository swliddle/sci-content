                            <h1>
                            Abrir Las Ventanas De Los Cielos
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1998/11/23.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/1998/11/23.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
