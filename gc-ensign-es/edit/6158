                            <h1>
                            &ldquo;Venid &hellip; Y Caminemos A La Luz Del Se&ntilde;or&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1998/11/37.p" class="" id="p">Mary Ellen Smoot</p>
