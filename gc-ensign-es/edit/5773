                            <h1>
                            La Conversi&oacute;n Y El Compromiso
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1996/04/29.p" class="" id="p">Elder W. Mark Lawrence</p>
				<p uri="/liahona/1996/04/29.p" class="" id="p">de los Setenta</p>
			</div>
