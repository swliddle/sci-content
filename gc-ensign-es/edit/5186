                            <h1>
                            Miremos A Lo Alto Y Sigamos Adelante
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/05/49.p" class="" id="p">Presidenta Elaine L. Jack</p>
				<p uri="/liahona/1992/05/49.p" class="" id="p">Presidenta General de la Sociedad de Socorro</p>
