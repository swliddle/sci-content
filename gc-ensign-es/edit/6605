                            <h1>
                            Cu&iacute;dense de murmurar
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2001/10/34.p" class="" id="p">&eacute;lder H. Ross Workman </p>
				<p uri="/liahona/2001/10/34.p" class="" id="p">De los Setenta </p>
