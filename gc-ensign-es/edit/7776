                                            <h4><a href="#" class="show">Mostrar las referencias</a></h4>
                                            
                                            <ol> <h3 class="title">Notas</h3> <li class="footnote " id="footnote1-09685_002_046"><a name="-09685_002_046">&nbsp;</a>
					<span class="label"><a name="footnote1-09685_002_046">1.</a></span>
					<p class="">V&eacute;ase <a href="https://www.lds.org/scriptures/pgp/a-of-f/1.13?lang=spa#12" target="_blank">Art&iacute;culos de Fe 1:13</a>.</p>
