                            <h1>
                            &ldquo;La bondad debe por m&iacute; empezar&rdquo;
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Mary N. Cook" data-desktop="/bc/content/shared/content/images/leaders/mary-n-cook-10.jpg">
