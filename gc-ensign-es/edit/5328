                            <h1>
                            Un Tapiz De Bondad
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/05/34.p" class="" id="p">Chieko N. Okazaki</p>
				<p uri="/liahona/1993/05/34.p" class="" id="p">Primera Consejera de la Presidencia General de la Sociedad de Socorro</p>
