                            <h1>
                            Our Only Chance
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1999/04/28.p" class="" id="p">Sheri L. Dew</p>
				<p uri="/liahona/1999/04/28.p" class="" id="p">Segunda Consejera de la Presidencia de la Sociedad de Socorro</p>
			</div>
