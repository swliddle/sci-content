                            <h1>
                            Las cosas peque&ntilde;as y sencillas
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Christoffel Golden Jr." data-desktop="/bc/content/shared/content/images/leaders/christoffel-golden-jr-10.jpg">
