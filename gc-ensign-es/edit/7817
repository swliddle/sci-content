                            <h1>
                            El poder de las Escrituras
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Richard G. Scott" data-desktop="/bc/content/shared/content/images/leaders/richard-g-scott-10.jpg">
