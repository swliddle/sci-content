                            <h1>
                            Toda mujer necesita la Sociedad de Socorro
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Silvia H. Allred" data-desktop="/bc/content/shared/content/images/leaders/silvia-h-allred-10.jpg">
