                            <h1>
                            Seamos El Viento Para El Se&ntilde;or
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="John H. Groberg" data-desktop="/bc/content/shared/content/images/leaders/john-h-groberg-10.jpg">
