                            <h1>
                            A&ntilde;oranza del hogar
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/11/11.p" class="" id="p">Elder Marvin J. Ashton</p>
				<p uri="/liahona/1992/11/11.p" class="" id="p">Del Qu&oacute;rum de los Doce Ap&oacute;stoles</p>
			</div>
