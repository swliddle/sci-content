                            <h1>
                            Ondas expansivas
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2000/11/39.p" class="" id="p">Virginia U. Jensen</p>
				<p uri="/liahona/2000/11/39.p" class="" id="p">Primera Consejera de la Presidencia General de la Sociedad de Socorro</p>
