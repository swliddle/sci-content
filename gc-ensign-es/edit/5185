                            <h1>
                            Saliva, Lodo Y Kigatsuku
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/05/47.p" class="" id="p">Chieko N. Okazaki</p>
				<p uri="/liahona/1992/05/47.p" class="" id="p">Primera Consejera de la Presidencia General de la Sociedad de Socorro</p>
