                                            <h4><a href="#" class="show">Mostrar las referencias</a></h4>
                                            
                                            <ol> <h3 class="title">Notas</h3> <li class="footnote " id="footnote1-14445_002_006"><a name="1-14445_002_006">&nbsp;</a>
