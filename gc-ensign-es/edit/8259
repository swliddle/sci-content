                                <h1>
                                <h1 data-aid="134803771" id="title1">Permanecer en Dios y reparar la brecha</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Neill F. Marriott" data-desktop="https://broadcast.lds.org/crowdsource/mobile/images/1255549/073840702ed040d4b0e52e435b94f623/100x139.jpg">
