                            <h1>
                            Las Cimas Espirituales
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1995/11/5.p" class="" id="p">Elder Jack H Goaslind </p>
				<p uri="/liahona/1995/11/5.p" class="" id="p">de los Setenta</p>
