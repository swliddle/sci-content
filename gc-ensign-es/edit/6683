                            <h1>
                            Permanecer en lugares santos
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Sharon G. Larsen" data-desktop="/bc/content/shared/content/images/leaders/sharon-g-larsen-10.jpg">
