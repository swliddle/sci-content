                            <h1>
                            El dar a conocer el Evangelio
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Robert C. Oaks" data-desktop="/bc/content/shared/content/images/leaders/robert-c-oaks-10.jpg">
