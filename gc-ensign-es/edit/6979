                            <h1>
                            La Expiaci&oacute;n: Todo por todo
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Bruce C. Hafen" data-desktop="/bc/content/shared/content/images/leaders/bruce-c-hafen-10.jpg">
