                            <h1>
                            Su paz
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Dennis E. Simmons" data-desktop="/bc/content/shared/content/images/leaders/dennis-e-simmons-10.jpg">
                                            <img src="/bc/content/shared/content/images/leaders/dennis-e-simmons-10.jpg" class="img-decor" alt="Dennis E. Simmons">
                                          </noscript>
