                                <h1>
                                <h1 data-aid="136378335" id="title1">La obra del templo y de historia familiar: Sellamiento y sanación</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="" data-desktop="https://edge.ldscdn.org/mobile/images/1658854/f6838dbffca6469c841b97cab319324e/100x139.jpg">
