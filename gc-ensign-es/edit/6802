                                    <div class="byline">
				<p uri="/liahona/2003/05/5.p2" class="" id="p2">&Eacute;lder David E. Sorensen</p>
				<p uri="/liahona/2003/05/5.p3" class="" id="p3">De la Presidencia de los Setenta</p>
			</div>
