                            <h1>
                            Lo Que Deseo Que Mi Nieto Sepa Antes De Salir En Una Misi&oacute;n
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1996/04/19.p" class="" id="p">Presidente James E. Faust</p>
