                            <h1>
                            Incluso un ni&ntilde;o puede entender
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2008/11/13.p2" class="" id="p2">&Eacute;lder G&eacute;rald Causs&eacute;</p>
				<p uri="/liahona/2008/11/13.p3" class="" id="p3">De los Setenta</p>
			</div>
                                    </section>
