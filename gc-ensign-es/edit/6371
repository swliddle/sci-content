                            <h1>
                            Somos creadores
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2000/05/27.p" class="" id="p">Mary Ellen Smoot</p>
				<p uri="/liahona/2000/05/27.p" class="" id="p">Presidenta General de la Sociedad de Socorro</p>
			</div>
