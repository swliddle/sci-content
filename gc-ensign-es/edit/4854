                            <h1>
                            &ldquo;A m&iacute; lo hicisteis&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1990/05/7.p" class="" id="p">por el &eacute;lder Richard P Lindsay</p>
				<p uri="/liahona/1990/05/7.p" class="" id="p">de los Setenta</p>
			</div>
