                            <h1>
                            &ldquo;&iquest;Es usted quien me imagino que es?&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1997/10/38.p" class="" id="p">Sheri L. Dew</p>
				<p uri="/liahona/1997/10/38.p" class="" id="p">Segunda Consejera de lo Presidencia General de lo Sociedad de Socorro</p>
