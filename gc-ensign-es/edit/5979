                            <h1>
                            Zapatos pioneros a trav&eacute;s de las edades
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1997/10/7.p" class="" id="p">Mary Ellen Smoot</p>
				<p uri="/liahona/1997/10/7.p" class="" id="p">Presidenta General de la Sociedad de Socorro</p>
