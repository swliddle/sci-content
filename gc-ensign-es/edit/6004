                            <h1>
                            La aplicaci&oacute;n universal del Evangelio
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1997/10/33.p" class="" id="p">Elder J. Kent Jolley</p>
				<p uri="/liahona/1997/10/33.p" class="" id="p">de los Setenta</p>
