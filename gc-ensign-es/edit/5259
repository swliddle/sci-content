                            <h1>
                            El Temor
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/11/38.p" class="" id="p">Virginia H. Pearce</p>
				<p uri="/liahona/1992/11/38.p" class="" id="p">Primera Consejera de la Presidencia de los Mujeres J&oacute;venes</p>
			</div>
