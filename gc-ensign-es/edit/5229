                            <h1>
                            Nuevas oportunidades de prestar servicio
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/11/7.p" class="" id="p">Elder Robert L Backman</p>
				<p uri="/liahona/1992/11/7.p" class="" id="p">Miembro Em&eacute;rito del Primer Qu&oacute;rum de los Setenta</p>
			</div>
                                    </section>
