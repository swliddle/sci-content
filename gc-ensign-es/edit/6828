                            <h1>
                            El matrimonio eterno
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="F. Burton Howard" data-desktop="/bc/content/shared/content/images/leaders/f-burton-howard-10.jpg">
