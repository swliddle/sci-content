                            <h1>
                            &ldquo;Anda Conmigo&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1994/04/7.p" class="" id="p">Elaine L. Jack</p>
				<p uri="/liahona/1994/04/7.p" class="" id="p">Presidenta General de la Sociedad de Socorro</p>
