                            <h1>
                            &ldquo;Ten animo, hija&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1997/10/32.p" class="" id="p">Elder Wayne M. Hancock</p>
