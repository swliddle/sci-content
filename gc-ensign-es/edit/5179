                            <h1>
                            La Fe Y Las Buenas Obras
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/05/35.p" class="" id="p">Elder Stephen D. Nadauld</p>
				<p uri="/liahona/1992/05/35.p" class="" id="p">De los Setenta</p>
