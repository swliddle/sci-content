                            <h1>
                            Fe, familia, hechos y frutos
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="M. Russell Ballard" data-desktop="/bc/content/shared/content/images/leaders/m-russell-ballard-10.jpg">
