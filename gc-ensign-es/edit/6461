                            <h1>
                            Manteng&aacute;monos erguidas y permanezcamos unidas
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2000/11/40.p" class="" id="p">Sheri L. Dew</p>
				<p uri="/liahona/2000/11/40.p" class="" id="p">Segunda Consejera de la Presidencia General de la Sociedad de Socorro</p>
