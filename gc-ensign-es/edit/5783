                            <h1>
                            Un Ancla Para La Eternidad Y Para Hoy
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1996/04/39.p" class="" id="p">Bonnie D. Parkin</p>
