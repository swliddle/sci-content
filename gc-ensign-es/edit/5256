                            <h1>
                            Un preciado patrimonio
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/11/35.p" class="" id="p">Elder James E. Faust</p>
				<p uri="/liahona/1992/11/35.p" class="" id="p">Del Qu&oacute;rum de los Doce Ap&oacute;stoles</p>
			</div>
