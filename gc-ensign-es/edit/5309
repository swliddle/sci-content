                            <h1>
                            La Fortaleza De La Iglesia Proviene De Cristo
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/05/15.p" class="" id="p">Elder V. Dallas Merrell</p>
				<p uri="/liahona/1993/05/15.p" class="" id="p">De los Setenta</p>
