                            <h1>
                            La paz
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1991/05/34.p" class="" id="p">Elder Robert E. Wells</p>
				<p uri="/liahona/1991/05/34.p" class="" id="p">De los Setenta</p>
			</div>
