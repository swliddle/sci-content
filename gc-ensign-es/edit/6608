                            <h1>
                            Constantes e inmutables
                            </h1>
                            <section class="author">
                                    <div class="byline">
				<p uri="/liahona/2001/10/37.p" class="" id="p">Mary Ellen Smoot </p>
				<p uri="/liahona/2001/10/37.p" class="" id="p">Presidenta General de la Sociedad de Socorro </p>
