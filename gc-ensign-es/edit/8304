                                <h1>
                                <h1 data-aid="136379141" id="title1">La enseñanza en el hogar: Una responsabilidad sagrada y gozosa</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="" data-desktop="https://edge.ldscdn.org/mobile/images/2071641/cef4d6875cbd484ea21b83eea325230d/100x139.jpg">
