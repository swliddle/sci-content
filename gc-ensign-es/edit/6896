                            <h1>
                            &Eacute;l nos conoce; &Eacute;l nos ama
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Sydney S. Reynolds" data-desktop="/bc/content/shared/content/images/leaders/sydney-s-reynolds-10.jpg">
