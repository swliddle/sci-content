                                            <ol> <h3 class="title">NOTAS</h3> <li class="footnote " id="footnote1-21991l_002_007"><a name="-21991l_002_007">&nbsp;</a>
				<span class="label">1.</span>
				<p class=""><a href="http://lds.org/scriptures/ot/ps/9.9-10?lang=spa#8" target="_blank">Salmos 9:9&ndash;10</a>.</p>
			</li><li class="footnote " id="footnote2-21991l_002_007"><a name="-21991l_002_007">&nbsp;</a>
