                            <h1>
                            &ldquo;Honrar&eacute; a los que me honran&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2001/05/21.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/2001/05/21.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
