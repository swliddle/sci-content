                            <h1>
                            Antes de levantar un muro
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1991/05/32.p" class="" id="p">Elder Loren C. Dunn</p>
				<p uri="/liahona/1991/05/32.p" class="" id="p">De los Setenta</p>
