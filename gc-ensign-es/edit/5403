                            <h1>
                            El Perd&oacute;n Divino
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/11/33.p" class="" id="p">Elder Ronald E. Poelman</p>
				<p uri="/liahona/1993/11/33.p" class="" id="p">De los Setenta</p>
