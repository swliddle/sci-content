                            <h1>
                            &ldquo;Mujer, &iquest;Por Que Lloras?&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1996/11/21.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/1996/11/21.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
			</div>
