                                    <div class="byline">
				<p uri="/liahona/1997/10/16.p" class="" id="p">Elder Joseph B. Wirthlin</p>
				<p uri="/liahona/1997/10/16.p" class="" id="p">del Qu&oacute;rum de los Doce Ap&oacute;stoles</p>
			</div>
