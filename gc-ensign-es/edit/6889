                            <h1>
                            El sacerdocio, las llaves y el poder para bendecir
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Merrill J. Bateman" data-desktop="/bc/content/shared/content/images/leaders/merrill-j-bateman-10.jpg">
