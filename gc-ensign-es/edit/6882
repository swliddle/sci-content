                            <h1>
                            C&oacute;mo recibir un testimonio del Evangelio restaurado de Jesucristo
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Robert D. Hales" data-desktop="/bc/content/shared/content/images/leaders/robert-d-hales-10.jpg">
