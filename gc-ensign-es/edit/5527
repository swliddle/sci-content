                            <h1>
                            Como Ayudar A Los Ni&ntilde;os A Discernir La Verdad Del Error
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1994/10/6.p" class="" id="p">Michaelene P. Grassli</p>
				<p uri="/liahona/1994/10/6.p" class="" id="p">Reci&eacute;n relevada Presidenta General de la Primaria</p>
