                            <h1>
                            La obra misional en Filipinas
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/11/34.p" class="" id="p">Elder Augusto A. Lim</p>
				<p uri="/liahona/1992/11/34.p" class="" id="p">De los Setenta</p>
