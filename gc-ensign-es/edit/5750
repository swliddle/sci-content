                            <h1>
                            La Voz Prof&eacute;tica
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1996/04/3.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/1996/04/3.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
			</div>
