                            <h1>
                            El llamado de advertencia de los profetas
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Shirley D. Christensen" data-desktop="/bc/content/shared/content/images/leaders/shirley-d-christensen-10.jpg">
