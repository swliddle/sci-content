                            <h1>
                            Cu&aacute;n Cerca de los &Aacute;ngles
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1998/04/41.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/1998/04/41.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
