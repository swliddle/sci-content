                            <h1>
                            &ldquo;Part&iacute;cipes De Las Glorias&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1996/11/28.p" class="" id="p">Presidenta Elaine L. Jack</p>
				<p uri="/liahona/1996/11/28.p" class="" id="p">Presidenta General de la Sociedad de Socorro</p>
