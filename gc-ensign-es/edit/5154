                            <h1>
                            Apacentemos El Reba&ntilde;o De Cristo
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/05/7.p" class="" id="p">Elder Alexander B. Morrison</p>
				<p uri="/liahona/1992/05/7.p" class="" id="p">De los Setenta</p>
