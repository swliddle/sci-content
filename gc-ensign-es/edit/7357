                            <h1>
                            El ser receptivos al Esp&iacute;ritu
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="A. Roger Merrill" data-desktop="/bc/content/shared/content/images/leaders/a-roger-merrill-10.jpg">
