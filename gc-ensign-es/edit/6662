                            <h1>
                            Lleguemos a ser hombres en quienes est&eacute; el esp&iacute;ritu de Dios
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="L. Tom Perry" data-desktop="/bc/content/shared/content/images/leaders/l-tom-perry-10.jpg">
