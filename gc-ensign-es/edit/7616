                            <h1>
                            La ense&ntilde;anza del Evangelio: nuestro llamamiento m&aacute;s importante
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="William D. Oswald" data-desktop="/bc/content/shared/content/images/leaders/william-d-oswald-10.jpg">
