                            <h1>
                            El Se&ntilde;or De Vida
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/05/5.p" class="" id="p">Elder J. Richard Clarke</p>
				<p uri="/liahona/1993/05/5.p" class="" id="p">De la Presidencia de los Setenta</p>
