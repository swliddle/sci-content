                            <h1>
                            Las Cosas Simples
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1994/10/31.p" class="" id="p">Elder Rex D. Pinegar</p>
				<p uri="/liahona/1994/10/31.p" class="" id="p">De la Presidencia de los Setenta</p>
			</div>
                                    </section>
