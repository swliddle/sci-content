                                  <ul><li><a href="http://www.facebook.com/sharer.php?u=https%3a//www.lds.org/liahona/1994/10/31%3flang%3dspa%26cid%3dfacebook-shared&amp;t=Las+Cosas+Simples+-+Liahona+1994-10-01" title="Facebook">Facebook</a></li><li><a href="http://twitter.com?status=https%3a//www.lds.org/liahona/1994/10/31%3flang%3dspa%26cid%3dtwitter-shared" title="Twitter">Twitter</a></li><li><a href="https://www.lds.org/secure/email?lang=spa&amp;cid=email-shared&amp;link=/liahona/1994/10/31&amp;title=Las+Cosas+Simples+-+Liahona+1994-10-01" title="Correo electr&oacute;nico">Correo electr&oacute;nico</a></li></ul>
