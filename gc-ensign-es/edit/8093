                            <h1>
                            El ser padres: Nuestro destino eterno
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Larry M. Gibson" data-desktop="/bc/content/shared/content/images/leaders/larry-m-gibson-10.jpg">
