                            <h1>
                            El amor de Cristo
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/11/15.p" class="" id="p">Elder C. Max Caldwell</p>
				<p uri="/liahona/1992/11/15.p" class="" id="p">De los Setenta</p>
			</div>
