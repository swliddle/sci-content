                            <h1>
                            Jos&eacute; Smith: Profeta de la Restauraci&oacute;n
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Tad R. Callister" data-desktop="/bc/content/shared/content/images/leaders/tad-r-callister-10.jpg">
