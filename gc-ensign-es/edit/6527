                            <h1>
                            C&oacute;mo mejorar nuestra experiencia en el templo
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2001/05/33.p" class="" id="p">&Eacute;lder L. Lionel Kendrick</p>
				<p uri="/liahona/2001/05/33.p" class="" id="p">De los Setenta</p>
