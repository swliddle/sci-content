                            <h1>
                            Si&oacute;n en medio de Babilonia
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="David R. Stone" data-desktop="/bc/content/shared/content/images/leaders/david-r-stone-10.jpg">
