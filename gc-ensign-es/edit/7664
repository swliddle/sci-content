                            <h1>
                            Ayudar a los dem&aacute;s a reconocer los susurros del Esp&iacute;ritu
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Vicki F. Matsumori" data-desktop="/bc/content/shared/content/images/leaders/vicki-f-matsumori-10.jpg">
                                            <img src="/bc/content/shared/content/images/leaders/vicki-f-matsumori-10.jpg" class="img-decor" alt="Vicki F. Matsumori">
                                          </noscript>
                                        </figure>
                                    <div class="byline">
				<p uri="/liahona/2009/11/5.p2" class="" id="p2">Vicki F. Matsumori</p>
				<p uri="/liahona/2009/11/5.p3" class="" id="p3">Segunda Consejera de la Presidencia General de la Primaria</p>
			</div>
                                    </section>
