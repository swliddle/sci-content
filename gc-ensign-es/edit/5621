                            <h1>
                            El Matrimonio Y El Gran Plan De Felicidad
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1995/04/27.p" class="" id="p">Elder Joe J. Christensen</p>
				<p uri="/liahona/1995/04/27.p" class="" id="p">de la Presidencia de los Setenta</p>
