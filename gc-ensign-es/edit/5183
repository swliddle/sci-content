                            <h1>
                            La Caridad Nunca Deja De Ser&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/05/39.p" class="" id="p">Presidenta Elaine L. Jack</p>
				<p uri="/liahona/1992/05/39.p" class="" id="p">Presidenta General de la Sociedad de Socorro</p>
			</div>
                                    </section>
