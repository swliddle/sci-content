                                <h1>
                                <h1 data-aid="134804758" id="title1">Preciosas y grandísimas promesas</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Elder David A. Bednar" data-desktop="https://broadcast.lds.org/crowdsource/mobile/images/1255497/3cef8ea8e02144f68e3dbf8825820531/100x132.jpg">
