                            <h1>
                            La Creaci&oacute;n
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Russell M. Nelson" data-desktop="/bc/content/shared/content/images/leaders/russell-m-nelson-10.jpg">
