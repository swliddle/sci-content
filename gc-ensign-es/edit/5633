                            <h1>
                            Que Coman &ldquo;De Este Fruto Hasta Quedar&rdquo; Satisfechas
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1995/04/39.p" class="" id="p">Janette C. Hales</p>
