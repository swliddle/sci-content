                            <h1>
                            Crezcamos En Esperanza
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1996/11/34.p" class="" id="p">Chieko N. Okazaki</p>
				<p uri="/liahona/1996/11/34.p" class="" id="p">Primera Consejera de la Presidencia de la Sociedad de Socorro</p>
			</div>
