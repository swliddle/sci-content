                            <h1>
                            A las mujeres de la Iglesia
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Howard W. Hunter" data-desktop="/bc/content/shared/content/images/leaders/howard-w-hunter-10.jpg">
