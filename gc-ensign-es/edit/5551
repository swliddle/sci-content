                            <h1>
                            &ldquo;Ense&ntilde;emos A Los Ni&ntilde;os&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1994/10/30.p" class="" id="p">Patricia P. Pinegar</p>
				<p uri="/liahona/1994/10/30.p" class="" id="p">Presidenta General de la Primaria</p>
