                            <h1>
                            Honremos El Sacerdocio
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/05/19.p" class="" id="p">Elder Russell M Nelson</p>
				<p uri="/liahona/1993/05/19.p" class="" id="p">Del Qu&oacute;rum de los Doce Ap&oacute;stoles</p>
			</div>
