                            <h1>
                            Uno entre la multitud
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2008/05/36.p2" class="" id="p2">&Eacute;lder Dennis B. Neuenschwander</p>
				<p uri="/liahona/2008/05/36.p3" class="" id="p3">De los Setenta</p>
			</div>
