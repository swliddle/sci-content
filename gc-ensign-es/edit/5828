                            <h1>
                            El Sal&oacute;n De Clase Com&uacute;n Y Corriente
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1996/11/6.p" class="" id="p">Virginia H. Pearce</p>
				<p uri="/liahona/1996/11/6.p" class="" id="p">Primera Consejera de la Presidencia General de las Mujeres J&oacute;venes</p>
