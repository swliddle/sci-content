                                    <div class="byline">
				<p uri="/liahona/2002/07/4.p2" class="" id="p2">&Eacute;lder Earl C. Tingey</p>
				<p uri="/liahona/2002/07/4.p3" class="" id="p3">De la Presidencia de los Setenta</p>
			</div>
