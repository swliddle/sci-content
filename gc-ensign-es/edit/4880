                            <h1>
                            Un samaritano de los &Uacute;ltimos d&iacute;as
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1990/05/36.p" class="" id="p">por el &eacute;lder Merlin R. Lybbert</p>
				<p uri="/liahona/1990/05/36.p" class="" id="p">de los Setenta</p>
