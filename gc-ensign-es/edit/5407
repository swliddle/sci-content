                            <h1>
                            La Fortaleza Que Nos Da Nuestro Salvador
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/11/37.p" class="" id="p">Chieko N. Okazaki</p>
				<p uri="/liahona/1993/11/37.p" class="" id="p">Primera Consejera de la Presidencia General de la Sociedad de Socorro</p>
