                            <h1>
                            Los Ni&ntilde;os Y la Familia
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1998/04/26.p" class="" id="p">&Eacute;lder W. Eugene Hansen </p>
				<p uri="/liahona/1998/04/26.p" class="" id="p">de la Presidencia de los Setenta</p>
			</div>
                                    </section>
