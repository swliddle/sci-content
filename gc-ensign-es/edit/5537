                            <h1>
                            El &ldquo;Fulgor Perfecto De Esperanza&rdquo;
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1994/10/16.p" class="" id="p">Elder Neil A. Maxwell</p>
				<p uri="/liahona/1994/10/16.p" class="" id="p">Del Qu&oacute;rum de los Doce Ap&oacute;stoles</p>
