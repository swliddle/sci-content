                            <h1>
                            Edifiquemos plazas fuertes
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1997/10/37.p" class="" id="p">Virginia U. Jensen</p>
				<p uri="/liahona/1997/10/37.p" class="" id="p">Primera Consejera de la Presidencia General de la Sociedad de Socorro</p>
