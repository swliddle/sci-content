                            <h1>
                            La Expiaci&oacute;n: nuestra mayor esperanza
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2001/10/8.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/2001/10/8.p" class="" id="p">Segundo Consejero de la Primera Presidencia </p>
