                            <h1>
                            Dediquen Tiempo A Sus Hijos
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Ben B. Banks" data-desktop="/bc/content/shared/content/images/leaders/ben-b-banks-10.jpg">
