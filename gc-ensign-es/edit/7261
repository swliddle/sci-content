                            <h1>
                            El don del albedr&iacute;o
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Wolfgang H. Paul" data-desktop="/bc/content/shared/content/images/leaders/wolfgang-h-paul-10.jpg">
