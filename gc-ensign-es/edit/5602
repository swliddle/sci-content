                            <h1>
                            El Templo Es Un Asunto De Familia
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1995/04/6.p" class="" id="p">Elder J Ballard Washburn </p>
