                            <h1>
                            Recordemos cu&aacute;n misericordioso ha sido el Se&ntilde;or
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Neal A. Maxwell" data-desktop="/bc/content/shared/content/images/leaders/neal-a-maxwell-10.jpg">
                                            <img src="/bc/content/shared/content/images/leaders/neal-a-maxwell-10.jpg" class="img-decor" alt="Neal A. Maxwell">
                                          </noscript>
                                        </figure>
                                    <div class="byline">
				<p uri="/liahona/2004/05/19.p2" class="" id="p2">&Eacute;lder Neal A. Maxwell</p>
				<p uri="/liahona/2004/05/19.p3" class="" id="p3">Del Qu&oacute;rum de los Doce Ap&oacute;stoles</p>
			</div>
                                    </section>
