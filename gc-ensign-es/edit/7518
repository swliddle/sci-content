                            <h1>
                            El poder para cambiar
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2007/11/45.p2" class="" id="p2">Presidente James E. Faust (1920&ndash;2007)</p>
				<p uri="/liahona/2007/11/45.p3" class="" id="p3">Segundo Consejero de la Primera Presidencia</p>
			</div>
                                    </section>
