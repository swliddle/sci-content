                            <h1>
                            El Libro De Morm&oacute;n: Una Antigua Historia Sagrada
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1995/11/15.p" class="" id="p">Elder Ted E. Brewerton</p>
				<p uri="/liahona/1995/11/15.p" class="" id="p">Miembro Em&eacute;rito del Primer Qu&oacute;rum de los Setenta</p>
			</div>
