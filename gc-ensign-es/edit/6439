                                    <div class="byline">
				<p uri="/liahona/2000/11/18.p" class="" id="p">&Eacute;lder Neal A. Maxwell</p>
				<p uri="/liahona/2000/11/18.p" class="" id="p">Del Qu&oacute;rum de los Doce Ap&oacute;stoles</p>
			</div>
