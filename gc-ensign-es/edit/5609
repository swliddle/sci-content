                            <h1>
                            Hemos Guardado La Fe
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1995/04/15.p" class="" id="p">Elder Eduardo Ayala </p>
				<p uri="/liahona/1995/04/15.p" class="" id="p">de los Setenta</p>
			</div>
                                    </section>
