                                    <div class="byline">
				<p uri="/liahona/2003/05/37.p2" class="" id="p2">Susan W. Tanner</p>
				<p uri="/liahona/2003/05/37.p3" class="" id="p3">Presidenta General de las Mujeres J&oacute;venes</p>
			</div>
                                    </section>
