                            <h1>
                            Cómo conservar el gran cambio en el corazón
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Dale G. Renlund" data-desktop="/bc/content/shared/content/images/leaders/dale-g-renlund-10.jpg">
