                            <h1>
                            Somos hijas de un Padre Celestial
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Elaine S. Dalton" data-desktop="/bc/content/shared/content/images/leaders/elaine-s-dalton-10.jpg">
