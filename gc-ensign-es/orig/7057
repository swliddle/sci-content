                            <h1>
                            El pertenecer es nuestra sagrada primogenitura
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Bonnie D. Parkin" data-desktop="/bc/content/shared/content/images/leaders/bonnie-d-parkin-10.jpg">
