                            <h1>
                            El Diezmo Un Privilegio
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1998/04/32.p" class="" id="p">Elder Ronald E. Poelman </p>
				<p uri="/liahona/1998/04/32.p" class="" id="p">de los Setenta</p>
			</div>
                                    </section>
