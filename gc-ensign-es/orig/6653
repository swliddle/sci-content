                            <h1>
                            Cómo obtener fortaleza interior
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2002/07/5.p2" class="" id="p2">Mary Ellen Smoot</p>
				<p uri="/liahona/2002/07/5.p3" class="" id="p3">Presidenta General de la Sociedad de Socorro recientemente relevada</p>
			</div>
                                    </section>
