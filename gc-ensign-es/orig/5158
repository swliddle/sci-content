                            <h1>
                            Paciencia En Las Aflicciones
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/05/14.p" class="" id="p">Elder Ángel Abrea</p>
				<p uri="/liahona/1992/05/14.p" class="" id="p">De los Setenta</p>
			</div>
                                    </section>
