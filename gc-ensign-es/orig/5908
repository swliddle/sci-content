                            <h1>
                            Un “Santo llamamiento”
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Monte J. Brough" data-desktop="/bc/content/shared/content/images/leaders/monte-j-brough-10.jpg">
