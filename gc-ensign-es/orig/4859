                            <h1>
                            Lecciones de las Escrituras sobre el liderazgo
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1990/05/15.p" class="" id="p">por el élder Spencer J. Condie</p>
				<p uri="/liahona/1990/05/15.p" class="" id="p">de los Setenta</p>
			</div>
