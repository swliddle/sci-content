                                <h1>
                                <h1 data-aid="134804209" id="title1">Ganar la confianza del Señor y la de su familia</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Elder Richard J. Maynes" data-desktop="https://broadcast.lds.org/crowdsource/mobile/images/1913074/97d29cd37ffa48f5896074744f8573c6/100x139.jpg">
