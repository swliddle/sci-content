                                    <div class="byline">
				<p uri="/liahona/2002/07/14.p2" class="" id="p2">Élder Robert R. Steuer</p>
				<p uri="/liahona/2002/07/14.p3" class="" id="p3">De los Setenta</p>
			</div>
