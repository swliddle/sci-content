                            <h1>
                            Seamos enseñables
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Robert R. Steuer" data-desktop="/bc/content/shared/content/images/leaders/robert-r-steuer-10.jpg">
