                            <h1>
                            Ayudemos a otros a obtener un testimonio
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1990/05/37.p" class="" id="p">por el élder H Burke Peterson</p>
				<p uri="/liahona/1990/05/37.p" class="" id="p">de los Setenta</p>
