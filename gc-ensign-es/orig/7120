                            <h1>
                            La fe es la respuesta
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="David E. Sorensen" data-desktop="/bc/content/shared/content/images/leaders/david-e-sorensen-10.jpg">
