                            <h1>
                            Cómo encontrar la paz y sanar el alma
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Dale E. Miller" data-desktop="/bc/content/shared/content/images/leaders/dale-e-miller-10.jpg">
                                            <img src="/bc/content/shared/content/images/leaders/dale-e-miller-10.jpg" class="img-decor" alt="Dale E. Miller">
                                          </noscript>
