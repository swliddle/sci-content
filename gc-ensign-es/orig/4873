                            <h1>
                            “Ni os jactéis de vuestra fe y obras poderosas”
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1990/05/29.p" class="" id="p">por el élder Marvin J Ashton</p>
				<p uri="/liahona/1990/05/29.p" class="" id="p">del Quórum de los Doce Apóstoles</p>
			</div>
