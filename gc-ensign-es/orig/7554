                                    <div class="byline">
				<p uri="/liahona/2008/05/8.p2" class="" id="p2">Élder Joseph B. Wirthlin</p>
				<p uri="/liahona/2008/05/8.p3" class="" id="p3">Del Quórum de los Doce Apóstoles</p>
			</div>
