                            <h1>
                            El espíritu del Tabernáculo
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Boyd K. Packer" data-desktop="/bc/content/shared/content/images/leaders/boyd-k-packer-10.jpg">
