                            <h1>
                            La Paz Por Medio De La Oracion
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/05/27.p" class="" id="p">Elder Rex D. Pinegar</p>
				<p uri="/liahona/1993/05/27.p" class="" id="p">De la Presidencia de los Setenta</p>
			</div>
