                            <h1>
                            "Alguna gran cosa"
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2001/10/21.p" class="" id="p">Presidente James E. Faust </p>
				<p uri="/liahona/2001/10/21.p" class="" id="p">Segundo Consejero de la Primera Presidencia </p>
