                            <h1>
                            Pioneras modernas
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1997/04/41.p" class="" id="p">Presidenta Janette Hales Beckham</p>
				<p uri="/liahona/1997/04/41.p" class="" id="p">Presidenta General de las Mujeres Jóvenes</p>
			</div>
