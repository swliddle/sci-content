                            <h1>
                            “Y tened compasión de los que dudan”
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Barbara Thompson" data-desktop="/bc/content/shared/content/images/leaders/barbara-thompson-10.jpg">
