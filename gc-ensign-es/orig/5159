                            <h1>
                            Desenredemos Nuestra Vida
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/05/15.p" class="" id="p">Elder William R. Bradford</p>
				<p uri="/liahona/1992/05/15.p" class="" id="p">De los Setenta</p>
			</div>
