                            <h1>
                            Tres decisiones
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Joseph B. Wirthlin" data-desktop="/bc/content/shared/content/images/leaders/joseph-b-wirthlin-10.jpg">
