                            <h1>
                            Vayan A La Sociedad De Socorro
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1998/11/38.p" class="" id="p">Virginia U. Jensen</p>
				<p uri="/liahona/1998/11/38.p" class="" id="p">Primera Consejera de la Presidencia General de la Sociedad de Socorro</p>
			</div>
                                    </section>
