                            <h1>
                            Las Grandes Llaves De La Sociedad De Socorro
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1996/11/36.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/1996/11/36.p" class="" id="p">Segundo Consejero de La Primera Presidencia</p>
