                            <h1>
                            La ley del diezmo
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Earl C. Tingey" data-desktop="/bc/content/shared/content/images/leaders/earl-c-tingey-10.jpg">
                                            <img src="/bc/content/shared/content/images/leaders/earl-c-tingey-10.jpg" class="img-decor" alt="Earl C. Tingey">
                                          </noscript>
                                        </figure>
                                    <div class="byline">
				<p uri="/liahona/2002/07/4.p2" class="" id="p2">Élder Earl C. Tingey</p>
				<p uri="/liahona/2002/07/4.p3" class="" id="p3">De la Presidencia de los Setenta</p>
			</div>
                                    </section>
