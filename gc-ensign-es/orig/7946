                            <h1>
                            Las palabras que expresamos
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Rosemary M. Wixom" data-desktop="/bc/content/shared/content/images/leaders/rosemary-m-wixom-10.jpg">
