                            <h1>
                            Cómo restaurar la fe en la familia
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Kenneth Johnson" data-desktop="/bc/content/shared/content/images/leaders/kenneth-johnson-10.jpg">
                                            <img src="/bc/content/shared/content/images/leaders/kenneth-johnson-10.jpg" class="img-decor" alt="Kenneth Johnson">
                                          </noscript>
