                                    <div class="byline">
				<p uri="/liahona/2008/05/7.p2" class="" id="p2">Élder Kenneth Johnson</p>
				<p uri="/liahona/2008/05/7.p3" class="" id="p3">De los Setenta</p>
			</div>
