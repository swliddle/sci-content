                            <h1>
                            Actuar Por Nosotros Mismos, Sin Ser Obligados
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1995/11/21.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/1995/11/21.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
