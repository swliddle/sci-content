                            <h1>
                            Recordemos cuán misericordioso ha sido el Señor
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Neal A. Maxwell" data-desktop="/bc/content/shared/content/images/leaders/neal-a-maxwell-10.jpg">
