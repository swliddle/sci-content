                            <h1>
                            Un Dios amoroso y comunicativo
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/11/26.p" class="" id="p">Elder Marion D. Hanks</p>
				<p uri="/liahona/1992/11/26.p" class="" id="p">Miembro Emérito del Primer Quórum de los Setenta</p>
			</div>
