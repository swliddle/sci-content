                            <h1>
                            Instrumentos de la paz del Señor
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Robert S. Wood" data-desktop="/bc/content/shared/content/images/leaders/robert-s-wood-10.jpg">
