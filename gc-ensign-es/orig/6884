                            <h1>
                            El Señor tu Dios te sostendrá de la mano
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="W. Craig Zwick" data-desktop="/bc/content/shared/content/images/leaders/w-craig-zwick-10.jpg">
