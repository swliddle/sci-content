                            <h1>
                            “Acuérdate … De Lo Que Has Recibido Y Oído”
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1996/04/31.p" class="" id="p">por Susan L Warner</p>
				<p uri="/liahona/1996/04/31.p" class="" id="p">Segunda Consejera de la Presidencia General de la Primaria</p>
			</div>
