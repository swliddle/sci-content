                                <h1>
                                <h1 data-aid="134804621" id="title1">¿Ha cesado el día de los milagros?</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Elder Donald L. Hallstrom" data-desktop="https://broadcast.lds.org/crowdsource/mobile/images/1911238/ff102e11c52b470ab7852666b6ebd9e9/100x139.jpg">
