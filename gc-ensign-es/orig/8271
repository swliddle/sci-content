                                            <noscript class="lazy" data-alt="Elder Ronald A. Rasband" data-desktop="https://broadcast.lds.org/crowdsource/mobile/images/1749864/20cd93fbc7bf4d75adc6a60a7a04e1b7/100x125.jpg">
