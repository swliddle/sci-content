                            <h1>
                            La eternidad ante nosotros
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1997/04/9.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/1997/04/9.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
			</div>
