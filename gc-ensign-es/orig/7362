                            <h1>
                            De nuevo llegaron profetas a la tierra
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Jeffrey R. Holland" data-desktop="/bc/content/shared/content/images/leaders/jeffrey-r-holland-10.jpg">
