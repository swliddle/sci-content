                            <h1>
                            ¿Está escrita en nuestro corazón la fe en la expiación de Jesucristo?
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Linda K. Burton" data-desktop="/bc/content/shared/content/images/leaders/linda-k-burton-10.jpg">
                                            <img src="/bc/content/shared/content/images/leaders/linda-k-burton-10.jpg" class="img-decor" alt="Linda K. Burton">
