                            <h1>
                            “La Honradez, Una Brújula De La Moral”
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1996/11/18.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/1996/11/18.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
