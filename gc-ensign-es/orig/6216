                            <h1>
                            Obedience: The Path to Freedom
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1999/04/22.p" class="" id="p">Presidente James E. Faust</p>
				<p uri="/liahona/1999/04/22.p" class="" id="p">Segundo Consejero de la Primera Presidencia</p>
			</div>
