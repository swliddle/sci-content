                            <h1>
                            “Creo en ser honrada y verídica”
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Ann M. Dibb" data-desktop="/bc/content/shared/content/images/leaders/ann-m-dibb-10.jpg">
                                            <img src="/bc/content/shared/content/images/leaders/ann-m-dibb-10.jpg" class="img-decor" alt="Ann M. Dibb">
