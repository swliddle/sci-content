                            <h1>
                            Fortalecer el hogar y la familia
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Carol B. Thomas" data-desktop="/bc/content/shared/content/images/leaders/carol-b-thomas-10.jpg">
                                            <img src="/bc/content/shared/content/images/leaders/carol-b-thomas-10.jpg" class="img-decor" alt="Carol B. Thomas">
                                          </noscript>
                                        </figure>
                                    <div class="byline">
				<p uri="/liahona/2002/07/39.p2" class="" id="p2">Carol B. Thomas</p>
				<p uri="/liahona/2002/07/39.p3" class="" id="p3">Primera Consejera de la Presidencia General de las Mujeres Jóvenes</p>
			</div>
