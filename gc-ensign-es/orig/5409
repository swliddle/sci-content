                            <h1>
                            “Examina La Senda De Tus Pies”
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/11/39.p" class="" id="p">Elaine L. Jack</p>
				<p uri="/liahona/1993/11/39.p" class="" id="p">Presidenta General de la Sociedad de Socorro</p>
			</div>
