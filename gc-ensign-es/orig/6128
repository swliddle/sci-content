                            <h1>
                            Escuchen La Voz Del Profeta
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1998/11/6.p" class="" id="p">Virginia U. Jensen</p>
			</div>
                                    </section>
