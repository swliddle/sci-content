                            <h1>
                            Las Decisiones
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1994/04/33.p" class="" id="p">Elder Gerald E. Melchin</p>
				<p uri="/liahona/1994/04/33.p" class="" id="p">De los Setenta</p>
			</div>
