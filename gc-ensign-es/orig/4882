                            <h1>
                            La gratitud: Un principio salvador
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1990/05/38.p" class="" id="p">por el élder James E Faust</p>
				<p uri="/liahona/1990/05/38.p" class="" id="p">del Quórum de los Doce Apóstoles</p>
