                            <h1>
                            La Crianza De Los Hijos En Un Ambiente Contaminado
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/11/6.p" class="" id="p">Elder Joe J. Christensen</p>
				<p uri="/liahona/1993/11/6.p" class="" id="p">De la Presidencia de los Setenta</p>
			</div>
                                    </section>
