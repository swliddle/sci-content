                            <h1>
                            El poder de un testimonio personal
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Dieter F. Uchtdorf" data-desktop="/bc/content/shared/content/images/leaders/dieter-f-uchtdorf-10.jpg">
