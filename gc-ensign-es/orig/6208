                            <h1>
                            “De Las Cosas Pequeñas”
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1999/04/14.p" class="" id="p">Elder Stephen A. West </p>
				<p uri="/liahona/1999/04/14.p" class="" id="p">de los Setenta</p>
