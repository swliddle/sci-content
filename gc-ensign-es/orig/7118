                            <h1>
                            Permanezcamos en lugares santos
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="James E. Faust" data-desktop="/bc/content/shared/content/images/leaders/james-e-faust-10.jpg">
                                            <img src="/bc/content/shared/content/images/leaders/james-e-faust-10.jpg" class="img-decor" alt="James E. Faust">
                                          </noscript>
                                        </figure>
                                    <div class="byline">
				<p uri="/liahona/2005/05/24.p2" class="" id="p2">Presidente James E. Faust</p>
				<p uri="/liahona/2005/05/24.p3" class="" id="p3">Segundo Consejero de la Primera Presidencia</p>
			</div>
                                    </section>
