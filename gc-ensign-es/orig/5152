                            <h1>
                            La Ley Real
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/05/5.p" class="" id="p">Elder Marion D. Hanks</p>
				<p uri="/liahona/1992/05/5.p" class="" id="p">De la Presidencia de los Setenta</p>
			</div>
