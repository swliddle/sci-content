                                <h1>
                                <h1 data-aid="134806512" id="title1">Verdades esenciales, nuestra necesidad de actuar</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Elder Adilson de Paula Parrella" data-desktop="https://broadcast.lds.org/crowdsource/mobile/images/1913250/eee587a61dec4a019b687ae1d2517066/100x139.jpg">
