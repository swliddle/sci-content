                            <h1>
                            Seamos hombres
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="D. Todd Christofferson" data-desktop="/bc/content/shared/content/images/leaders/d-todd-christofferson-10.jpg">
