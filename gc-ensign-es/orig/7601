                            <h1>
                            Ora siempre
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="David A. Bednar" data-desktop="/bc/content/shared/content/images/leaders/david-a-bednar-10.jpg">
