                            <h1>
                            ‘‘Escudriñad Las Escrituras”
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/05/7.p" class="" id="p">Elder L Lionel Kendrick</p>
				<p uri="/liahona/1993/05/7.p" class="" id="p">De los Setenta</p>
			</div>
