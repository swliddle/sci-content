                                <h1>
                                <h1 data-aid="136381216" id="title1">Prepárense para presentarse ante Dios</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="" data-desktop="https://edge.ldscdn.org/mobile/images/1255509/9edc398376e3431788ceb62e046a5b32/100x133.jpg">
