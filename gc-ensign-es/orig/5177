                            <h1>
                            No Estamos Solos
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/05/33.p" class="" id="p">Janette C. Hales</p>
				<p uri="/liahona/1992/05/33.p" class="" id="p">Presidenta General de los Mujeres Jóvenes</p>
			</div>
