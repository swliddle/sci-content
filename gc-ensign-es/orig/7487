                            <h1>
                            De las cosas pequeñas
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2007/11/14.p2" class="" id="p2">Élder Michael Teh</p>
				<p uri="/liahona/2007/11/14.p3" class="" id="p3">De los Setenta</p>
			</div>
