                            <h1>
                            Un Prisionero De Amor
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/05/21.p" class="" id="p">Elder Vaughn J. Featherstone</p>
				<p uri="/liahona/1992/05/21.p" class="" id="p">De los Setenta</p>
			</div>
                                    </section>
