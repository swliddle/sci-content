                                <h1>
                                <h1 data-aid="134791359" id="title1">El pan vivo que ha descendido del cielo</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Elder D. Todd Christofferson" data-desktop="https://broadcast.lds.org/crowdsource/mobile/images/1255505/a0fc63690e6244fd9ddf436d08092e4a/100x132.jpg">
