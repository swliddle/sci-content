                            <h1>
                            Establecer un hogar centrado en Cristo
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Richard J. Maynes" data-desktop="/bc/content/shared/content/images/leaders/richard-j-maynes-10.jpg">
