                            <h1>
                            Padre, Vuelve A Tu Hogar
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/05/18.p" class="" id="p">Elder James E. Faust</p>
				<p uri="/liahona/1993/05/18.p" class="" id="p">Del Quórum de los Doce Apóstoles</p>
			</div>
