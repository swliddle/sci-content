                            <h1>
                            El Espíritu De Profecía
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1996/11/5.p" class="" id="p">Élder L. Aldin Porter</p>
				<p uri="/liahona/1996/11/5.p" class="" id="p">de la Presidencia de los Setenta</p>
			</div>
