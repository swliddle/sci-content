                            <h1>
                            La fe, el servicio y la constancia
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/2006/11/7.p2" class="" id="p2">Élder David S. Baxter</p>
				<p uri="/liahona/2006/11/7.p3" class="" id="p3">De los Setenta</p>
			</div>
                                    </section>
