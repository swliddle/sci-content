                            <h1>
                            “Sed De Buen Ánimo”
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1993/11/38.p" class="" id="p">Jeanne Inouye</p>
				<p uri="/liahona/1993/11/38.p" class="" id="p">Del Barrio Provo Decimosexto, de la Estaca Edgemont, Provo, Utah</p>
			</div>
