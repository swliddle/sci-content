                            <h1>
                            Crecer en el Señor
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Anne C. Pingree" data-desktop="/bc/content/shared/content/images/leaders/anne-c-pingree-10.jpg">
