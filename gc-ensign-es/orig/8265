                                <h1>
                                <h1 data-aid="134790688" id="title1">“Tengo una obra para ti”</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Elder John C. Pingree Jr." data-desktop="https://broadcast.lds.org/crowdsource/mobile/images/1913251/e78383304b4d4fc48a37b3232a9e80ca/100x139.jpg">
