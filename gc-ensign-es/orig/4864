                            <h1>
                            El Sacerdocio Aarónico: “Regresemos con honor”
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1990/05/20.p" class="" id="p">Obispo Robert D Hales</p>
