                                    <div class="byline">
				<p uri="/liahona/2003/05/33.p2" class="" id="p2">Élder D. Rex Gerratt</p>
				<p uri="/liahona/2003/05/33.p3" class="" id="p3">De los Setenta</p>
			</div>
