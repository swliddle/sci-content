                            <h1>
                            Sigan las instrucciones
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="D. Rex Gerratt" data-desktop="/bc/content/shared/content/images/leaders/d-rex-gerratt-10.jpg">
