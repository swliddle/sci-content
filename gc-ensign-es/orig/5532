                            <h1>
                            Perseverar Hasta El Fin Con Caridad
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1994/10/11.p" class="" id="p">Elder Hartman Rector, Jr.</p>
				<p uri="/liahona/1994/10/11.p" class="" id="p">Autoridad General emérita miembro de los Setenta</p>
			</div>
