                            <h1>
                            Cinco Panes De Cebada Y Dos Panecillos
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1994/04/3.p" class="" id="p">Elder James E. Faust</p>
				<p uri="/liahona/1994/04/3.p" class="" id="p">Del Quórum de los Doce Apóstoles</p>
			</div>
                                    </section>
