                                    <div class="byline">
				<p uri="/liahona/2006/05/34.p2" class="" id="p2">Élder Joseph B. Wirthlin</p>
				<p uri="/liahona/2006/05/34.p3" class="" id="p3">Del Quórum de los Doce Apóstoles</p>
			</div>
