                                            <h4><a href="#" class="show">Mostrar las referencias</a></h4>
                                            
                                            <ol> <h3 class="title">Notas</h3> <li class="footnote " id="footnote1-26985_002_034"><a name="-26985_002_034"> </a>
				<span class="label">
	<a name="footnote1-26985_002_034">1.</a>
      </span>
				<p class="">Véase Rutherford George Montgomery, <span class="emphasis">Snowman, </span>1962.</p>
			</li><li class="footnote " id="footnote2-26985_002_034"><a name="-26985_002_034"> </a>
				<span class="label">
	<a name="footnote2-26985_002_034">2.</a>
