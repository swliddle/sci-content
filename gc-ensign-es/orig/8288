                                            </noscript>
                                        </figure>
                                    <p data-aid="134806836" id="p1">Por el élder Stanley G. Ellis</p><p data-aid="134806840" id="p2">Miembro emérito de los Setenta</p>
                                    </section>
                                
                                
                                
