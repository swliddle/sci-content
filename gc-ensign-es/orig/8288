                                <h1>
                                <h1 data-aid="134806818" id="title1">¿Confiamos en Él? Lo difícil es bueno</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Elder Stanley G. Ellis" data-desktop="https://broadcast.lds.org/crowdsource/mobile/images/1913170/1cfb25dd515c4d869c7b0b19e38afad8/100x139.jpg">
