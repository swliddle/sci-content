                            <h1>
                            “El Corazón Y Una Mente Bien Dispuesta”
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1998/04/20.p" class="" id="p">Elder James M. Paramore </p>
				<p uri="/liahona/1998/04/20.p" class="" id="p">de los Setenta</p>
			</div>
