                            <h1>
                            El “Fulgor Perfecto De Esperanza”
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1994/10/16.p" class="" id="p">Elder Neil A. Maxwell</p>
				<p uri="/liahona/1994/10/16.p" class="" id="p">Del Quórum de los Doce Apóstoles</p>
