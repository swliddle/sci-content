                            <h1>
                            Mantengamos sagrado los templos
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1990/05/25.p" class="" id="p">por el presidente Gordon B Hinckley</p>
				<p uri="/liahona/1990/05/25.p" class="" id="p">Primer Consejero de lo Primera Presidencia</p>
			</div>
