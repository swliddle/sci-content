                                <h1>
                                <h1 data-aid="134805047" id="title1">No tengáis miedo de hacer lo bueno</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="President Henry B. Eyring" data-desktop="https://broadcast.lds.org/crowdsource/mobile/images/1255525/ddea4dc7d13149b5adcb7d6908cd12e3/100x133.jpg">
