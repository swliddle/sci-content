                            <h1>
                            Sanidad Espiritual
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1992/05/4.p" class="" id="p">Elder James E. Faust</p>
				<p uri="/liahona/1992/05/4.p" class="" id="p">Del Quórum de los Doce Apóstoles</p>
			</div>
