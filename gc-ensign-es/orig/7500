                            <h1>
                            No dejen para mañana lo que puedan hacer hoy
                            </h1>
                            <section class="author">
                                     <figure class="head-shot">
                                          <noscript class="lazy" data-alt="Claudio R. M. Costa" data-desktop="/bc/content/shared/content/images/leaders/claudio-r-m-costa-10.jpg">
