                            <h1>
                            Seamos Obedientes
                            </h1>
                            <section class="author">
                                     
                                    <div class="byline">
				<p uri="/liahona/1994/04/19.p" class="" id="p">Elder Joseph E. Wirthlin</p>
				<p uri="/liahona/1994/04/19.p" class="" id="p">Del Quórum de los Doce Apóstoles</p>
			</div>
