                                <h1>
                                <h1 data-aid="138546665" id="title1">The Role of the Book of Mormon in Conversion</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Elder Shayne M. Bowen" data-desktop="https://mobile-cdn.lds.org/09/6f/096feb77bcf07aeadf3e76bbed4bb918967e0806/shayne_bowen_official_portrait_2017.jpg">
