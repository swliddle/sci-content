                                <h1>
                                <h1 data-aid="138546689" id="title1">The Vision of the Redemption of the Dead</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="President M. Russell Ballard" data-desktop="https://mobile-cdn.lds.org/19/c4/19c4838685a64eb70f4ece7bf12ddedb340ab4d7/elder_m_russell_ballard_lds.jpg">
