                                <h1>
                                <h1 data-aid="138546786" id="title1">Wounded</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Elder Neil L. Andersen" data-desktop="https://edge.ldscdn.org/mobile/images/1255490/3d517516d6924e7499b1a942d323dd2b/100x133.jpg">
