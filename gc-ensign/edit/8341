                                <h1>
                                <h1 data-aid="138544750" id="title1">Believe, Love, Do</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Elder Dieter F. Uchtdorf" data-desktop="https://mobile-cdn.lds.org/ec/0b/ec0bb2f64d3544d05b8a46a9269329fa5eb07d78/president_dieter_f_uchtdorf_lds.jpg">
