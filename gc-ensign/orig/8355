                                <h1>
                                <h1 data-aid="138546306" id="title1">The Father</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Brian K. Ashton" data-desktop="https://mobile-cdn.lds.org/c1/4c/c14c6ddb12b087d17bec0417550ff465442809c7/sunday_school_general_presidency_2018.jpeg">
