                                <h1>
                                <h1 data-aid="138544641" id="title1">Sisters’ Participation in the Gathering of Israel</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="President Russell M. Nelson" data-desktop="https://mobile-cdn.lds.org/81/01/8101824fe4eaf68c5ba335e48032c2c7d6451a66/president_russell_m_nelson_portrait.jpeg">
