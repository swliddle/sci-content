                                <h1>
                                <h1 data-aid="138546444" id="title1">Wilt Thou Be Made Whole?</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Elder Matthew L. Carpenter" data-desktop="https://mobile-cdn.lds.org/f6/a7/f6a7acb13fc083ddf7ff29ac417ba9eeb92f2630/matthew_carpenter_quorum_seventy_2018.jpeg">
