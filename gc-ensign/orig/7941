                    $('#video-player').mediaLoader({
                        template:"#media-template-video",
                        mediaList:mediaList,
                        hashLabel:'watch',
                        playerOptions : {
                            "wmode":"transparent",
                            "isVid":"true",
                            "isUI":"true",
                            "dynamicStreaming":"true",
                            "bgcolor":"#fff",
                            "width":470,
                            "height":264
                        },
                        onopen:function(event, self){
                            if(self.curMedia.type != "audio"){
                                //get down below fixed navigation bar, but only if we need to
                                var targetTop = self.element.offset().top-65;
                                if($(window).scrollTop() > targetTop) {
                                    window.scrollTo(0,targetTop);
                                }
                                if(self.curMedia.type != "image"){
                                    $(".media-placeholder",self.element).css("min-height",self.options.playerOptions.height);
                                }
                            }
                        }
                    });
                }
            });
        });
