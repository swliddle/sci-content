                                <h1>
                                <h1 data-aid="138543533" id="title1">Divine Discontent</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Michelle D. Craig" data-desktop="https://mobile-cdn.lds.org/ac/b2/acb2a4c66bcf7efd1c100d7c5d0379079805d76a/young_women_presidency_portrait_craig.jpeg">
