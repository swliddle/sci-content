                                <h1>
                                <h1 data-aid="136099534" id="title1">Young Women in the Work</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Bonnie L. Oscarson" data-desktop="https://edge.ldscdn.org/mobile/images/1255562/7de2dad240cd454f90ce8384311a1488/100x135.jpg">
