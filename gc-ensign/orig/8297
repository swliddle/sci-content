                                <h1>
                                <h1 data-aid="136099838" id="title1">The Heart of a Prophet</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Elder Gary E. Stevenson" data-desktop="https://edge.ldscdn.org/mobile/images/1655146/0d6c3b5d48594e58acdd8820cdf24470/100x139.jpg">
