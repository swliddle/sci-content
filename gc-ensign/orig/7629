                                        <ol>
    <h3 class="title">Notes</h3>
			
			<li class="footnote " id="-04205_000_006"><a name="-04205_000_006">&nbsp;</a>
				<span class="label">
	<a name="footnote1-04205_000_006">1.</a>
      </span>
