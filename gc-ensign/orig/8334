                                <h1>
                                <h1 data-aid="138544945" id="title1">Gather Together in One All Things in Christ</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Elder David A. Bednar" data-desktop="https://mobile-cdn.lds.org/49/25/4925a3ff74eddb34b16258435bf9a9dcd488b7d4/elder_david_a_bednar_lds.jpg">
