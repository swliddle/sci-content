    <h3 class="title">Notes</h3>
			
			<li class="footnote " id="-23911_000_025"><a name="-23911_000_025">&nbsp;</a>
				<span class="label">
	<a name="footnote1-23911_000_025">1.</a>
      </span>
				<p><a href="http://lds.org/scriptures/nt/john/10.14?lang=eng#13" onclick="newWindow(this.href); return false;">John 10:14</a>.</p>
			</li>
			<li class="footnote " id="-23911_000_025"><a name="-23911_000_025">&nbsp;</a>
				<span class="label">
	<a name="footnote2-23911_000_025">2.</a>
      </span>
				<p><a href="http://lds.org/scriptures/nt/john/10.3?lang=eng#2" onclick="newWindow(this.href); return false;">John 10:3</a>.</p>
			</li>
			<li class="footnote " id="-23911_000_025"><a name="-23911_000_025">&nbsp;</a>
				<span class="label">
