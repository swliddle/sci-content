                                <h1>
                                <h1 data-aid="136099944" id="title1">Ministering as the Savior Does</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Jean B. Bingham" data-desktop="https://edge.ldscdn.org/mobile/images/1976746/590e84d465e74447b10ddaa0f2394364/100x139.jpg">
