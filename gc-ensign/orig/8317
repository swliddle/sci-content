                                <h1>
                                <h1 data-aid="136100092" id="title1">His Spirit to Be with You</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="President Henry B. Eyring" data-desktop="https://edge.ldscdn.org/mobile/images/2060290/f3f00bd95a41485bbfa8d6c25705fae1/100x133.jpg">
