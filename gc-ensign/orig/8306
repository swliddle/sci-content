                                <h1>
                                <h1 data-aid="136099053" id="title1">What Every Aaronic Priesthood Holder Needs to Understand</h1>
                                </h1>
                                <section class="author">
                                    <figure class="head-shot">
                                            <noscript class="lazy" data-alt="Douglas D. Holmes" data-desktop="https://edge.ldscdn.org/mobile/images/2071643/9b36d53ec0af4c1ebe8aa7782a0ce4ab/100x139.jpg">
